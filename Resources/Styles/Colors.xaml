<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryDarkText">#F8FAFC</Color>
    <Color x:Key="Accent">#14B8A6</Color>
    <Color x:Key="AccentSoft">#CCFBF1</Color>
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningSoft">#FEF3C7</Color>
    <Color x:Key="WarningText">#92400E</Color>
    <Color x:Key="Success">#16A34A</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#020617</Color>
    <Color x:Key="PageBg">#F6F8FB</Color>
    <Color x:Key="PageBgDark">#0B1117</Color>
    <Color x:Key="PanelBg">#FFFFFF</Color>
    <Color x:Key="PanelBgDark">#111827</Color>
    <Color x:Key="PanelAlt">#F8FAFC</Color>
    <Color x:Key="PanelAltDark">#182235</Color>
    <Color x:Key="PanelRaised">#FFFFFF</Color>
    <Color x:Key="PanelRaisedDark">#131D2B</Color>
    <Color x:Key="ControlBg">#EEF4FA</Color>
    <Color x:Key="ControlBgDark">#1C293B</Color>
    <Color x:Key="TextStrong">#0F172A</Color>
    <Color x:Key="TextStrongDark">#E5EDF7</Color>
    <Color x:Key="TextMuted">#64748B</Color>
    <Color x:Key="TextMutedDark">#9CAFC4</Color>
    <Color x:Key="BorderSoft">#D9E2EC</Color>
    <Color x:Key="BorderSoftDark">#29384D</Color>
    <Color x:Key="ChipBg">#CCFBF1</Color>
    <Color x:Key="ChipBgDark">#123B3D</Color>
    <Color x:Key="ChipText">#0F766E</Color>
    <Color x:Key="ChipTextDark">#7DD3C7</Color>

    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray900">#0F172A</Color>
    <Color x:Key="Gray950">#020617</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="PageBgBrush" Color="{StaticResource PageBg}" />
    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBg}" />
    <SolidColorBrush x:Key="PanelAltBrush" Color="{StaticResource PanelAlt}" />
    <SolidColorBrush x:Key="TextStrongBrush" Color="{StaticResource TextStrong}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource BorderSoft}" />
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />
</ResourceDictionary>
